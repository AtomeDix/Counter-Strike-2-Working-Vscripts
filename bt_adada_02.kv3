{
	//config = "scripts/ai/deathmatch/bt_config.kv3"
	config = "scripts/ai/uLLeticaL/aim_botz/bt_config.kv3"
	root =
	{
		type = "decorator_bot_service"
		memory_to_expire =
		[
			{
				key = "ShortTermAttackMemory"
				time = 0.7
				distance = 0
			},
			{
				key = "LongTermMemory"
				time = 10
				distance = 500
			},
			{
				key = "ShortTermInvestigateMemory"
				time = 3
				distance = 200
			}
		]
		child =
		{
			//type = "decorator_buy_service"
			//output = "ShouldBuy"
			//child =
			//{
				type = "parallel"
				children =
				[
					{
						type = "decorator_repeat"
						child =
						{
							type = "parallel"
							children =
							[
								// memorize enemies through vision
								{
									type = "subtree"
									file = "scripts/ai/uLLeticaL/aim_botz/modules/bt_memorize_enemies_vision.kv3"
									name = "MemorizeEnemiesVision"
								},
								// memorize noises happening right now
								{
									type = "subtree"
									file = "scripts/ai/uLLeticaL/aim_botz/modules/bt_memorize_noises.kv3"
									name = "MemorizeNoises"
								},
								// record the nearest memorized event to investigate
								{
									type = "subtree"
									file = "scripts/ai/uLLeticaL/aim_botz/modules/bt_memorize_nearest_investigation.kv3"
									name = "MemorizeNearestInvestigation"
								},
								{
									type = "decorator_sensor"
									shape =
									{
										type = "sensor_shape_sphere"
									}
									entity_type_filter = "PLAYERS"
									team_filter = "ENEMY"
									output = "WallhackerBot"
									priority = 0
									child = 
									{
										type = "decorator_picker_nearby"
										input = "WallhackerBot"
										cutoff_distance = 5000
										output = "WallhackerBot"
									}
								}
							]
						}
					},
					{
						type = "decorator_repeat"
						child =
						{
							type = "selector"
							children =
							[
								// Buy if we have to
								// {
								// 	type = "condition_is_empty"
								// 	input = "ShouldBuy"
