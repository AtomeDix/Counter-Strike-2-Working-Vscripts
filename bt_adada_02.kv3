								// 			}
								// 		]
								// 	}
								// },
								// Else: face the damage source if we're taking damage
								{
									type = "decorator_sensor"
									entity_type_filter = "DAMAGE"
									output = "Damage"
									priority = 0
									child =
									{
										type = "condition_is_empty"
										input = "Damage"
										negated = 1
										child =
										{
											type = "action_aim"
											input = "Damage"
											acquire_only = 1
										}
									}
								},
								// Else: attack if we see an enemy
								{
									type = "subtree"
									file = "scripts/ai/uLLeticaL/aim_botz/modules/bt_attack.kv3"
									name = "Attack"
								},
								{
									type = "subtree"
									file = "scripts/ai/uLLeticaL/aim_botz/modules/btm_hunt_player.kv3"
									name = "HuntPlayer"
								}

								// {
								// 	type = "subtree"
								// 	file = "scripts/ai/uLLeticaL/aim_botz/modules/bt_heal_if_needed.kv3"
								// 	name = "HealIfNeeded"
